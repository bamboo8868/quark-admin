{
  "name": "nodejs-fastify-mvc",
  "version": "1.0.0",
  "description": "Node.js MVC framework with Fastify, Knex, Redis, JWT and decorator-based routing",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "set NODE_ENV=dev&& node --watch src/app.js",
    "start": "set NODE_ENV=prod&& node src/app.js",
    "migrate": "set NODE_ENV=development&& knex migrate:latest",
    "migrate:prod": "set NODE_ENV=production&& knex migrate:latest",
    "migrate:rollback": "set NODE_ENV=development&& knex migrate:rollback",
    "migrate:rollback:prod": "set NODE_ENV=production&& knex migrate:rollback",
    "create-admin": "node scripts/create-super-admin.js",
    "seed": "set NODE_ENV=development&& knex seed:run",
    "seed:prod": "set NODE_ENV=production&& knex seed:run",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "fastify",
    "knex",
    "redis",
    "jwt",
    "mvc",
    "javascript",
    "decorators"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.9.7",
    "pg": "^8.11.5",
    "pino": "^8.21.0",
    "pino-pretty": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
